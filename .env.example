# .env.example — commit THIS file, never your real .env.
#
#   1. `.env` is gitignored. Never commit real keys.
#   2. Copy it:  cp .env.example .env   then fill real values locally.
#   3. If a real key ever lands in a commit, it is compromised — ROTATE it (regenerate).
#      Deleting the file is not enough; git history keeps it.
#   4. In CI/deploy, put real values in GitHub → Settings → Secrets and variables.
#
# List every variable your project needs, with a dummy/placeholder value:

# --- Backend ---
PORT=8080
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=REPLACE_ME

# Local Supabase (`supabase start`)
DATABASE_URL=jdbc:postgresql://localhost:54322/postgres
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# Cloud Run must use the IPv4-compatible Supabase session pooler, not the
# IPv6-only db.<project-ref>.supabase.co direct endpoint. Copy these values from
# Supabase Dashboard -> Connect -> Session pooler, then add the jdbc: prefix and
# ?sslmode=require to its URL.
# DATABASE_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# DB_USER=postgres.PROJECT_REF
# DB_PASSWORD=YOUR_RAW_DATABASE_PASSWORD

# Hikari connections per API instance. Keep this small when Cloud Run can scale
# to multiple instances.
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=0
